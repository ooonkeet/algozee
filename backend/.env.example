# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/algozee

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_this_too
JWT_REFRESH_EXPIRE=30d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CLIENT_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Code Execution (Phase 6) ─────────────────────────────────────────────────
# Optional: plug in Judge0 for multi-language execution
# JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
# JUDGE0_API_KEY=your_rapidapi_key

# ─── Badge / Gamification ─────────────────────────────────────────────────────
# Points awarded per difficulty
POINTS_EASY=10
POINTS_MEDIUM=25
POINTS_HARD=50
